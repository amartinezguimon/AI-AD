# Cloud backend configuration. Copy to .env (git-ignored) and edit for the VM.
# Local dev needs NONE of these — defaults run on SQLite with zero setup.

# PostgreSQL connection (production). Format:
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
VM_DATABASE_URL=postgresql+psycopg2://visionmetrics:CHANGE_ME@db:5432/visionmetrics

# Secret used to sign dashboard login tokens. Generate a long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VM_JWT_SECRET=CHANGE_ME

VM_ENVIRONMENT=production

# Used by docker-compose for the Postgres container + Caddy domain.
POSTGRES_USER=visionmetrics
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=visionmetrics
VM_DOMAIN=localhost
